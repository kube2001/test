<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>AMD株価チャート＆関連ニュース</title>
  <script src="https://cdn.jsdelivr.net/npm/vue@2.6.14/dist/vue.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 0;
      background-color: #121212;
      color: white;
    }
    #app {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }
    #header {
      background-color: #1e1e1e;
      padding: 20px;
      text-align: center;
    }
    #content {
      display: flex;
      flex-direction: column;
      flex-grow: 1;
      padding: 20px;
    }
    #tvChart {
      margin-bottom: 20px;
      flex-grow: 1;
    }
    #news {
      background-color: #1e1e1e;
      padding: 20px;
      border-radius: 8px;
    }
    a {
      color: #00bcd4;
      text-decoration: none;
    }
    a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div id="app">
    <div id="header">
      <h1>AMD 株価チャート ＆ 最新ニュース</h1>
    </div>
    <div id="content">
      <div id="tvChart" style="max-width: 1320px; height: 500px;">
        <div class="tradingview-widget-container">
          <div id="tradingview_amd"></div>
          <script type="text/javascript" src="https://s3.tradingview.com/tv.js"></script>
          <script type="text/javascript">
            new TradingView.widget({
              "width": "100%",
              "height": 500,
              "symbol": "NASDAQ:AMD",
              "interval": "5",
              "timezone": "America/New_York",
              "theme": "dark",
              "style": "1",
              "locale": "ja",
              "toolbar_bg": "#111",
              "enable_publishing": false,
              "allow_symbol_change": false,
              "container_id": "tradingview_amd"
            });
          </script>
        </div>
      </div>
      <div id="news">
        <h2>最新ニュース</h2>
        <ul>
          <li v-for="item in news" :key="item.link">
            <a :href="item.link" target="_blank">{{ item.title }}</a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <script>
    new Vue({
      el: '#app',
      data: {
        news: []
      },
      methods: {
        async fetchNews() {
          const rssUrl = 'https://news.google.com/rss/search?q=amd+stock&hl=ja&gl=JP&ceid=JP:ja';
          const corsProxy = 'https://api.allorigins.win/get?url=' + encodeURIComponent(rssUrl);

          try {
            const response = await axios.get(corsProxy);
            const parser = new DOMParser();
            const xml = parser.parseFromString(response.data.contents, "text/xml");
            const items = xml.querySelectorAll("item");
            this.news = Array.from(items).slice(0, 10).map(item => ({
              title: item.querySelector("title").textContent,
              link: item.querySelector("link").textContent
            }));
          } catch (error) {
            console.error("ニュース取得エラー:", error);
          }
        }
      },
      mounted() {
        this.fetchNews();
      }
    });
  </script>
</body>
</html>
